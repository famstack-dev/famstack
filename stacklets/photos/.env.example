# stacklets/photos/.env.example
#
# You do NOT need to copy or edit this file.
# 'stack enable photos' constructs all environment variables automatically
# from stack.toml (data_dir, timezone) and .famstack/secrets.toml (DB_PASSWORD).
#
# This file is reference documentation — showing what variables Immich receives
# and where their values come from.

# ── Set by stack.toml [core] data_dir ────────────────────────────────────────
# UPLOAD_LOCATION   = {data_dir}/photos/library    — photo library (back this up)
# DB_DATA_LOCATION  = {data_dir}/photos/postgres   — Postgres data (must be on SSD)

# ── Set by stack.toml [core] timezone ────────────────────────────────────────
# TZ = {timezone}

# ── Auto-generated, stored in .famstack/secrets.toml ────────────────────────
# DB_PASSWORD — random 32-char alphanumeric, generated on first enable
#               run 'stack config --secrets' to retrieve it

# ── Fixed defaults (set in stacklet.toml [env.defaults]) ────────────────────
# DB_USERNAME      = postgres
# DB_DATABASE_NAME = immich
# IMMICH_VERSION   = release    (tracks latest stable; pin to e.g. v1.130.0 for manual control)
