#!/usr/bin/env bash
# stacktests — operate the integration test stack.
#
# The test rig uses the repo root as its instance (same layout as a
# real famstack: stack.toml, users.toml, .stack/ at the root). A
# sentinel `.stack/.test-instance` marks the repo as test-owned;
# running the rig over someone's real stack errors out instead of
# overwriting it.
#
# Usage (callable from anywhere — paths resolve off the script location):
#   tests/integration/stacktests up              — bring up what tests need
#   tests/integration/stacktests down            — stop every test stacklet
#   tests/integration/stacktests reset [slet]    — destroy + up (clean slate)
#   tests/integration/stacktests cleanup         — nuke every test stacklet +
#                                                  instance state + test data
#   tests/integration/stacktests e2e [args]      — run every e2e test
#   tests/integration/stacktests eval [args]     — pipeline quality eval
#                                                  (real model, report-only)
#   tests/integration/stacktests pytest [args]   — pytest with env + deps
#   tests/integration/stacktests <any stack cmd> — forward: logs, status...

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
# Defensive: clear any STACK_DIR the user may have exported pointing at
# a legacy test-instance path. The rig owns the repo root now.
unset STACK_DIR
export PYTHONPATH="$REPO_ROOT/lib"
cd "$REPO_ROOT"

# Stacklets the e2e tests need, in dependency order.
# - core: always_on, provides the bot-runner container that actually
#   executes the archivist bot (which then auto-creates #documents).
# - messages: Synapse + Element (Matrix backbone).
# - docs: Paperless-ngx + archivist bot definition.
# - code: Forgejo — archivist mirrors classified documents here.
REQUIRED_STACKLETS=(core messages docs code)

# Stacklets that `down` and `cleanup` deliberately leave alone. The
# ai stacklet downloads large models on install, which costs minutes
# of wall time and gigabytes of disk on every reinstall; across a day
# of iterative test runs that adds up. When an e2e test actually
# needs a fresh ai state, tear it down explicitly with
# `stacktests down ai` or `stack destroy ai --yes`.
PRESERVED_STACKLETS=(ai)

# Bootstrap the repo root as a test instance and seed global secrets.
# Fails loudly if the repo root already holds a non-test stack.toml —
# see _seed_secrets.py's TestInstanceConflict message for the cleanup
# hint the user gets.
seed_secrets() {
  python3 "$SCRIPT_DIR/_seed_secrets.py"
}

case "${1:-}" in
  up)
    # `./stacktests up`  — bring up the full set in order.
    # `./stacktests up X` — forward to `stack up X`.
    seed_secrets
    if [[ -z "${2:-}" ]]; then
      for sid in "${REQUIRED_STACKLETS[@]}"; do
        echo "==> stack up $sid"
        python3 -m stack up "$sid"
      done
    else
      shift
      exec python3 -m stack up "$@"
    fi
    ;;

  down)
    # Stop everything the tests care about, leaving PRESERVED_STACKLETS
    # (notably ai) running so their heavy state isn't thrown away. A
    # specific target on the command line is forwarded verbatim, so
    # `stacktests down ai` still works when a fresh ai state is wanted.
    shift || true
    if [[ -z "${1:-}" ]]; then
      for sid in "${REQUIRED_STACKLETS[@]}"; do
        echo "==> stack down $sid"
        python3 -m stack down "$sid" || true
      done
    else
      exec python3 -m stack down "$@"
    fi
    ;;

  reset)
    # Destroy + up — recover from a half-bootstrapped state without
    # hunting down setup markers or stale containers. --yes skips the
    # destroy confirmation because this is a test stack.
    shift || true
    if [[ -z "${1:-}" ]]; then
      targets=("${REQUIRED_STACKLETS[@]}")
    else
      targets=("$@")
    fi
    for sid in "${targets[@]}"; do
      echo "==> stack destroy $sid --yes"
      python3 -m stack destroy "$sid" --yes || true
    done
    for sid in "${targets[@]}"; do
      echo "==> stack up $sid"
      python3 -m stack up "$sid"
    done
    ;;

  pytest)
    # Run pytest with the test-deps extra and the env already set.
    shift
    exec uv run --extra test pytest "$@"
    ;;

  e2e)
    # Run every end-to-end test under tests/integration/. Convention:
    # any file named test_*_e2e.py is picked up. Extra args forward to
    # pytest (e.g. `stacktests e2e -s -k homer`).
    #
    # Seeds secrets + brings up required stacklets first. Both steps
    # are idempotent, so repeat runs pay near-zero cost.
    shift || true
    seed_secrets
    for sid in "${REQUIRED_STACKLETS[@]}"; do
      python3 -m stack up "$sid" > /dev/null
    done
    exec uv run --extra test pytest tests/integration/ -k "_e2e" "$@"
    ;;

  eval)
    # Pipeline quality eval — uploads each case to a real Paperless,
    # waits for OCR, runs `enrich_document` against the live AI stacklet,
    # and prints a per-field scorecard. Report-only by design (always
    # passes) so prompt iteration is friction-free.
    #
    # Excluded from default pytest collection (see pyproject.toml's
    # `norecursedirs`). The only way in is this subcommand.
    #
    # Required env (set in your shell before running):
    #   AI_DEFAULT_MODEL — concrete model name to evaluate (e.g. "qwen3-14b")
    # Optional env:
    #   EVAL_AI_URL=http://localhost:42060/v1   AI endpoint (default shown)
    #   EVAL_AI_KEY=                            empty for unauthenticated local AI
    #   EVAL_KEEP_DOCS=1                        keep uploaded docs in Paperless
    #                                           after the run for inspection
    #
    # Per-run artifacts (OCR text, classification JSON, scorecard) are
    # always written to tests/integration/eval/runs/<stamp>_<model>/.
    #
    # Pre-flight: requires `ai` to be up — fails fast with a clear
    # message rather than auto-installing models on someone's machine.
    #
    # Pytest args forward verbatim, so case selection is just `-k <expr>`:
    #   stacktests eval -k rechnung           one case
    #   stacktests eval -k 'rezept or kassenbon'   subset by substring
    #   stacktests eval --collect-only -q     list available cases
    shift || true
    seed_secrets
    for sid in "${REQUIRED_STACKLETS[@]}"; do
      python3 -m stack up "$sid" > /dev/null
    done
    exec uv run --extra test pytest -s -v tests/integration/eval/ "$@"
    ;;

  cleanup)
    # Nuke everything test-related so the next `up` starts from zero.
    #   1. Destroy each stacklet (containers, per-stacklet secrets,
    #      per-stacklet data dir, setup marker).
    #   2. Wipe the test instance's .stack/ — clears global secrets
    #      (ADMIN_PASSWORD, user passwords) that survive per-stacklet
    #      destroy by design.
    #   3. Wipe the test data directory — catches detritus from runs
    #      that aborted before destroy could clean per-stacklet.
    #
    # Scope is confined to the test-owned repo root and ~/famstack-test-data.
    # The .test-instance sentinel confirms we're touching a test-owned repo,
    # so a real user's famstack at the same path would need to be cleaned up
    # by hand before this ever ran (guarded by _seed_secrets.py).

    shift || true
    TEST_DATA_DIR="${HOME}/famstack-test-data"

    for sid in "${REQUIRED_STACKLETS[@]}"; do
      echo "==> stack destroy $sid --yes"
      python3 -m stack destroy "$sid" --yes || true
    done

    # Belt and suspenders: force-remove any stack-<id>-* containers that
    # survived destroy (e.g. if compose_down silently errored). Without
    # this, a lingering container talking to a wiped data dir confuses
    # the next `up` into a schema-mismatch crash loop.
    for sid in "${REQUIRED_STACKLETS[@]}"; do
      leftovers=$(docker ps -aq --filter "name=^stack-${sid}-" 2>/dev/null || true)
      if [[ -n "$leftovers" ]]; then
        echo "==> docker rm -f (leftover stack-${sid}-* containers)"
        echo "$leftovers" | xargs docker rm -f || true
      fi
    done

    # Only remove repo root state if we own it (sentinel present).
    # Setup markers and data for PRESERVED_STACKLETS are kept so the
    # heavy state (ai's model downloads) survives a cleanup cycle.
    if [[ -f "$REPO_ROOT/.stack/.test-instance" ]]; then
      # Build a find exclusion list for the preserved-stacklet markers
      # plus the .test-instance sentinel itself. Every other entry
      # under .stack/ (global secrets, other setup markers) is wiped.
      preserve_args=(! -name '.test-instance')
      for sid in "${PRESERVED_STACKLETS[@]}"; do
        preserve_args+=(! -name "${sid}.*")
      done
      echo "==> clean $REPO_ROOT/.stack (preserving: ${PRESERVED_STACKLETS[*]})"
      find "$REPO_ROOT/.stack" -mindepth 1 -maxdepth 1 \
        "${preserve_args[@]}" -exec rm -rf {} +
      for f in stack.toml users.toml; do
        if [[ -f "$REPO_ROOT/$f" ]]; then
          echo "==> rm $REPO_ROOT/$f"
          rm -f "$REPO_ROOT/$f"
        fi
      done
    else
      echo "==> skipping repo-root cleanup (no .stack/.test-instance sentinel)"
    fi

    if [[ -d "$TEST_DATA_DIR" ]]; then
      data_preserve_args=()
      for sid in "${PRESERVED_STACKLETS[@]}"; do
        data_preserve_args+=(! -name "$sid")
      done
      echo "==> clean $TEST_DATA_DIR (preserving: ${PRESERVED_STACKLETS[*]})"
      find "$TEST_DATA_DIR" -mindepth 1 -maxdepth 1 \
        "${data_preserve_args[@]}" -exec rm -rf {} + 2>/dev/null || true
    fi

    echo ""
    echo "✓ Test stack cleaned. Next 'stacktests up' starts fresh."
    echo "   (preserved across cleanup: ${PRESERVED_STACKLETS[*]})"
    ;;

  "")
    python3 -m stack
    ;;

  *)
    # Anything else — forward untouched to stack.
    exec python3 -m stack "$@"
    ;;
esac
