# User configuration — never commit
stack.toml
config.sh
users.toml
# …except the test instance's config, which is checked in.
!tests/integration/instance/stack.toml
!tests/integration/instance/users.toml

# Runtime state — generated by stack CLI
.stack/

# Per-stacklet runtime state — never commit
**/.state/

# Per-stacklet secrets — never commit
**/.env

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
.python-version

# Editor
.vscode/
.idea/
*.swp
*.swo

# Auto-generated secrets — never commit
.stack/secrets.toml

# Test artifacts
.coverage
htmlcov/
.pytest_cache/

# AI assistant
.claude/

# Internal development notes
impl/

# JetBrains
*.iml

**CLAUDE.md
**AGENT.md